// Copy this file to Secrets.xcconfig (same folder) and fill in real values.
// Secrets.xcconfig is gitignored — the real key must never be committed.
//
// WARNING: the key is baked into the app's Info.plist and is trivially
// recoverable from any build of the app. This is acceptable ONLY for local
// testing on your own devices. Never ship a build configured this way.

// Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY = your-gemini-api-key-here

// Your Apple Development Team ID (Xcode > Settings > Accounts, or leave the
// placeholder and pick a team in Signing & Capabilities instead).
DEVELOPMENT_TEAM = ABCDE12345
